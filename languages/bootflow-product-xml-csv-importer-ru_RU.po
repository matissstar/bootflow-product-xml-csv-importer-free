msgstr "Неизвестная ошибка загрузки."

#: includes/class-bfpi-security.php:140
msgid "Invalid file name."
msgstr "Недопустимое имя файла."

#: includes/class-bfpi-security.php:149
msgid "File type not allowed. Only XML and CSV files are supported."
msgstr "Тип файла не разрешён. Поддерживаются только XML и CSV файлы."

#: includes/class-bfpi-security.php:156
msgid "File is too large. Maximum size is 100MB."
msgstr "Файл слишком большой. Максимальный размер 100МБ."

#: includes/class-bfpi-security.php:168
msgid "File MIME type does not match extension."
msgstr "MIME-тип файла не соответствует расширению."

#: includes/class-bfpi-security.php:174
msgid "File contains potentially malicious content."
msgstr "Файл содержит потенциально вредоносный контент."

#: includes/class-bfpi-security.php:417
msgid "Invalid URL format."
msgstr "Недопустимый формат URL."

#: includes/class-bfpi-security.php:424
msgid "URL must use HTTP or HTTPS protocol."
msgstr "URL должен использовать протокол HTTP или HTTPS."

#: includes/class-bfpi-security.php:428
msgid "URL must contain a valid host."
msgstr "URL должен содержать действительный хост."

#: includes/class-bfpi-security.php:436
msgid "Localhost URLs are not allowed."
msgstr "URL-адреса localhost не допускаются."

#: includes/class-bfpi-security.php:441
msgid "Local domain URLs are not allowed."
msgstr "URL-адреса локальных доменов не допускаются."

#: includes/class-bfpi-security.php:449
msgid "URLs pointing to private or reserved IP ranges are not allowed."
msgstr ""
"URL-адреса, указывающие на приватные или зарезервированные IP-диапазоны, не "
"допускаются."

