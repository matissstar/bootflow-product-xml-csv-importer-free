msgstr "⚠️ Zmiana filtrów wpłynie na przyszłe importy. Istniejące produkty nie zostaną automatycznie zmienione."

#: includes/admin/partials/import-edit.php:659
msgid "⚠️ If unchecked: Products not matching filters will be skipped during import, but existing products will remain Published."
msgstr "⚠️ Jeśli odznaczony: Produkty niepasujące do filtrów zostaną pominięte podczas importu, ale istniejące produkty pozostaną Opublikowane."

#: includes/admin/partials/step-2-mapping.php:2400
msgid "✅ Access any XML field: <code>$value . \" - \" . $brand</code>"
msgstr "✅ Dostęp do dowolnego pola XML: <code>$value . \" - \" . $brand</code>"

#: includes/admin/partials/step-2-mapping.php:2399
msgid "✅ Complex formulas need return: <code>if ($value > 100) { return $value * 0.9; } return $value;</code>"
msgstr "✅ Złożone formuły wymagają return: <code>if ($value > 100) { return $value * 0.9; } return $value;</code>"

#: includes/admin/partials/step-2-mapping.php:2398
msgid "✅ Simple formulas work directly: <code>$value * 1.2</code>"
msgstr "✅ Proste formuły działają bezpośrednio: <code>$value * 1.2</code>"

